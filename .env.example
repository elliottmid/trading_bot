# Schwab API Credentials
SCHWAB_API_KEY=your_app_key_here
SCHWAB_API_SECRET=your_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=/Users/elliottmiddleton/trading-bot/token.json

# Trading Parameters
SYMBOLS=SPY,QQQ,IWM,SCHD,BRK/B,BTC,CHAT,DIA,EEM,EWH,FXI,ILF,PHYS,PSLV,RSP
LIVE_TRADING=false
DRY_RUN=true
LOOP_INTERVAL_SECONDS=60

# Model Parameters
LOOKBACK_DAYS=252
PREDICTION_HORIZON=5
MIN_CONFIDENCE=0.65

# Risk Management
MAX_POSITION_SIZE_PCT=0.05
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=5.0
MAX_DAILY_LOSS_PCT=2.0

# External Signals (optional)
FINVIZ_API_KEY=
TRADINGVIEW_WEBHOOK_KEY=
SIGNAL_AGREEMENT_WEIGHT=0.2

# Logging
LOG_LEVEL=INFO
LOG_PATH=./logs/bot.log
